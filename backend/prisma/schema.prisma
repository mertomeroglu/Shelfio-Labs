generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String    @id
  externalTenantId String?   @unique @map("external_tenant_id")
  name             String
  slug             String    @unique
  status           String    @default("active")
  payload          Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  stores           Store[]
  licenses         License[]
  sessions         LicenseSession[]
  exportJobs       ExportJob[]

  @@map("tenants")
}

model Store {
  id        String    @id
  tenantId  String    @map("tenant_id")
  name      String
  code      String?
  status    String    @default("active")
  payload   Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  LicenseSession[]
  settings  Setting[]

  @@index([tenantId])
  @@map("stores")
}

model Plan {
  id             String    @id
  code           String    @unique
  name           String
  enabledModules Json?     @map("enabled_modules")
  storeLimit     Int?      @map("store_limit")
  userLimit      Int?      @map("user_limit")
  payload        Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  licenses       License[]

  @@map("plans")
}

model License {
  id                String    @id
  tenantId          String    @map("tenant_id")
  planId            String?   @map("plan_id")
  planCode          String?   @map("plan_code")
  licenseKeyHash    String    @unique @map("license_key_hash")
  externalLicenseId String?   @unique @map("external_license_id")
  externalTenantId  String?   @map("external_tenant_id")
  licenseOwnerEmail String?   @map("license_owner_email")
  externalPlan      String?   @map("external_plan")
  externalStatus    String?   @map("external_status")
  status            String    @default("pending")
  enabledModules    Json?     @map("enabled_modules")
  storeLimit        Int?      @map("store_limit")
  userLimit         Int?      @map("user_limit")
  expiresAt         DateTime? @map("expires_at")
  activatedAt       DateTime? @map("activated_at")
  payload           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan              Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  sessions          LicenseSession[]
  setupTokens       SsoSetupToken[]
  exportJobs        ExportJob[]

  @@index([tenantId])
  @@index([status])
  @@map("licenses")
}

model LicenseSession {
  id        String    @id
  tenantId  String    @map("tenant_id")
  licenseId String    @map("license_id")
  storeId   String?   @map("store_id")
  tokenHash String    @map("token_hash")
  status    String    @default("active")
  expiresAt DateTime  @map("expires_at")
  payload   Json?
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  license   License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([licenseId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("license_sessions")
}

model ExportJob {
  id                String    @id
  tenantId          String    @map("tenant_id")
  licenseId         String?   @map("license_id")
  externalLicenseId String    @map("external_license_id")
  externalTenantId  String?   @map("external_tenant_id")
  requestedByEmail  String?   @map("requested_by_email")
  status            String    @default("queued")
  scope             String    @default("tenant")
  includeAuditLogs  Boolean   @default(false) @map("include_audit_logs")
  fileName          String?   @map("file_name")
  fileBasename      String?   @map("file_basename")
  downloadTokenHash String?   @unique @map("download_token_hash")
  downloadExpiresAt DateTime? @map("download_expires_at")
  downloadCount     Int       @default(0) @map("download_count")
  lastDownloadedAt  DateTime? @map("last_downloaded_at")
  requestId         String?   @map("request_id")
  callbackUrl       String?   @map("callback_url")
  errorCode         String?   @map("error_code")
  errorMessage      String?   @map("error_message")
  payload           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  license           License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([licenseId])
  @@index([status])
  @@index([createdAt])
  @@index([downloadExpiresAt])
  @@map("export_jobs")
}

model SsoSetupToken {
  id                String    @id
  tokenHash         String    @unique @map("token_hash")
  exchangeCodeHash  String    @unique @map("exchange_code_hash")
  localLicenseId    String?   @map("local_license_id")
  externalLicenseId String    @map("external_license_id")
  externalTenantId  String?   @map("external_tenant_id")
  licenseOwnerEmail String    @map("license_owner_email")
  licensePlan       String?   @map("license_plan")
  licenseStatus     String    @map("license_status")
  payload           Json?
  expiresAt         DateTime  @map("expires_at")
  usedAt            DateTime? @map("used_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  localLicense      License?  @relation(fields: [localLicenseId], references: [id], onDelete: SetNull)

  @@index([externalLicenseId])
  @@index([expiresAt])
  @@map("sso_setup_tokens")
}

model User {
  id                   String                     @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  username             String
  passwordHash         String?                    @map("password_hash")
  role                 String?
  assignedDeskCode     String?                    @map("assigned_desk_code")
  name                 String?
  email                String?
  isActive             Boolean?                   @map("is_active")
  lastLoginAt          DateTime?                  @map("last_login_at")
  registerPin          String?                    @map("register_pin")
  storeId              String?                    @map("store_id")
  department           String?
  permissions          Json?
  payload              Json?
  createdAt            DateTime?                  @map("created_at")
  updatedAt            DateTime?                  @map("updated_at")
  tasksAssigned        Task[]                     @relation("TaskAssignedTo")
  tasksCreated         Task[]                     @relation("TaskCreatedBy")
  sales                Sale[]
  stockMovements       StockMovement[]
  warehouseMovements   WarehouseMovement[]
  purchaseOrdersCreated PurchaseOrder[]
  purchaseOrderStatusRows PurchaseOrderStatusHistory[]
  purchaseOrderActivityRows PurchaseOrderActivityLog[]
  accessRequests       AccessRequest[]            @relation("AccessRequestUser")
  createdAccessRequests AccessRequest[]           @relation("AccessRequestCreator")
  reviewedAccessRequests AccessRequest[]          @relation("AccessRequestReviewer")
  temporaryGrants      TemporaryPermissionGrant[]
  temporaryGrantsApproved TemporaryPermissionGrant[] @relation("TemporaryGrantApprover")
  temporaryGrantsRevoked TemporaryPermissionGrant[] @relation("TemporaryGrantRevoker")
  transferRequestsCreated StockTransferRequest[]  @relation("TransferRequestedBy")
  transferRequestsHandled StockTransferRequest[]  @relation("TransferHandledBy")
  transferAudits       TransferAudit[]
  taskComments         TaskComment[]

  @@unique([tenantId, username])
  @@map("users")
}

model Category {
  id                 String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  name               String
  normalizedSearch   String?   @map("normalized_search")
  code               String?   @unique
  description        String?
  mainSectionNo      Int?      @map("main_section_no")
  mainSectionName    String?   @map("main_section_name")
  mainStorageType    String?   @map("main_storage_type")
  requiresColdChain  Boolean?  @map("requires_cold_chain")
  requiresFreezer    Boolean?  @map("requires_freezer")
  isActive           Boolean?  @map("is_active")
  payload            Json?
  createdAt          DateTime? @map("created_at")
  updatedAt          DateTime? @map("updated_at")
  products           Product[]
  purchaseSuggestions PurchaseSuggestion[]

  @@map("categories")
}

model Section {
  id          String                 @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  number      Int?                   @unique
  name        String?
  description String?
  isActive    Boolean?               @map("is_active")
  payload     Json?
  createdAt   DateTime?              @map("created_at")
  updatedAt   DateTime?              @map("updated_at")
  products    Product[]
  transfers   StockTransferRequest[]
  beaconDevices BeaconDevice[]
  locationZones LocationZone[]

  @@map("sections")
}

model Supplier {
  id                   String              @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  supplierCode         String?             @map("supplier_code")
  code                 String?
  name                 String
  normalizedSearch     String?             @map("normalized_search")
  type                 String?
  tedarikciTuru        String?             @map("tedarikci_turu")
  website              String?
  minimumOrderQty      Int?                @map("minimum_order_qty")
  minimumOrderCaseQty  Int?                @map("minimum_order_case_qty")
  coveredCategories    Json?               @map("covered_categories")
  delayStatus          String?             @map("delay_status")
  linkedProductCount   Int?                @map("linked_product_count")
  isActive             Boolean?            @map("is_active")
  categories           Json?
  productCount         Int?                @map("product_count")
  payload              Json?
  createdAt            DateTime?           @map("created_at")
  updatedAt            DateTime?           @map("updated_at")
  products             Product[]
  supplierProducts     SupplierProduct[]
  purchaseSuggestions  PurchaseSuggestion[]
  purchaseOrders       PurchaseOrder[]
  warehouseLocations   WarehouseLocation[]
  warehouseMovements   WarehouseMovement[]
  stockMovements       StockMovement[]
  catalogImports       CatalogImport[]

  @@map("suppliers")
}

model Product {
  id                                String                 @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  sku                               String
  barcode                           String?
  name                              String
  normalizedSearch                  String?                @map("normalized_search")
  brand                             String?
  categoryId                        String?                @map("category_id")
  supplierId                        String?                @map("supplier_id")
  sectionId                         String?                @map("section_id")
  shelfSide                         String?                @map("shelf_side")
  shelfNo                           Int?                   @map("shelf_no")
  shelfLevel                        Int?                   @map("shelf_level")
  shelfCode                         String?                @map("shelf_code")
  requiredStorageType               String?                @map("required_storage_type")
  unit                              String?
  purchasePrice                     Decimal?               @map("purchase_price") @db.Decimal(14, 4)
  salePrice                         Decimal?               @map("sale_price") @db.Decimal(14, 4)
  etiket                            String?
  placementPriority                 String?                @map("placement_priority")
  averageDesi                       Decimal?               @map("average_desi") @db.Decimal(12, 3)
  criticalStock                     Int?                   @map("critical_stock")
  maxShelfStock                     Int?                   @map("max_shelf_stock")
  maxStock                          Int?                   @map("max_stock")
  unitsPerCase                      Int?                   @map("units_per_case")
  casesPerPallet                    Int?                   @map("cases_per_pallet")
  unitsPerPallet                    Int?                   @map("units_per_pallet")
  minimumOrderCaseQty               Int?                   @map("minimum_order_case_qty")
  isListed                          Boolean?               @map("is_listed")
  registerOnOrder                   Boolean?               @map("register_on_order")
  catalogVisibility                 String?                @map("catalog_visibility")
  orderActivatedStatus              String?                @map("order_activated_status")
  isActive                          Boolean?               @map("is_active")
  sourceSheet                       String?                @map("source_sheet")
  depotAssignmentType               String?                @map("depot_assignment_type")
  depotLocationCode                 String?                @map("depot_location_code")
  depotZoneCode                     String?                @map("depot_zone_code")
  isVirtualLocation                 Boolean?               @map("is_virtual_location")
  capacityMode                      String?                @map("capacity_mode")
  stockingStrategy                  String?                @map("stocking_strategy")
  assignmentPriority                Int?                   @map("assignment_priority")
  depotLocationLabel                String?                @map("depot_location_label")
  defaultWarehouseLocationCode      String?                @map("default_warehouse_location_code")
  alternativeWarehouseLocationCodes Json?                  @map("alternative_warehouse_location_codes")
  payload                           Json?
  createdAt                         DateTime?              @map("created_at")
  updatedAt                         DateTime?              @map("updated_at")
  priceUpdatedAt                    DateTime?              @map("price_updated_at")
  lastPriceChangeDate               DateTime?              @map("last_price_change_date")
  lastPriceChangeAt                 DateTime?              @map("last_price_change_at")
  lastPriceChangeSource             String?                @map("last_price_change_source")
  category                          Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier                          Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  section                           Section?               @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  stock                             Stock?
  supplierProducts                  SupplierProduct[]
  stockMovements                    StockMovement[]
  warehouseLocations                WarehouseLocation[]
  warehouseMovements                WarehouseMovement[]
  purchaseSuggestions               PurchaseSuggestion[]
  purchaseOrderItems                PurchaseOrderItem[]
  saleItems                         SaleItem[]
  stockTransferRequests             StockTransferRequest[]
  eslDevices                        EslDevice[]
  eslHistory                        EslHistory[]
  priceEvents                       ProductPriceEvent[]
  temporaryPriceActions             TemporaryPriceAction[]
  mobileOrderItems                  MobileOrderItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([categoryId])
  @@index([supplierId])
  @@index([sectionId])
  @@map("products")
}

model TemporaryPriceAction {
  id                      String    @id @default(uuid())
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId               String    @map("product_id")
  oldPrice                Decimal?  @map("old_price") @db.Decimal(14, 4)
  appliedPrice            Decimal   @map("applied_price") @db.Decimal(14, 4)
  actionType              String?   @map("action_type")
  recommendationType      String?   @map("recommendation_type")
  riskLevel               String?   @map("risk_level")
  startAt                 DateTime  @map("start_at")
  endAt                   DateTime  @map("end_at")
  durationDays            Int       @map("duration_days")
  appliedBy               String?   @map("applied_by")
  appliedAt               DateTime  @map("applied_at")
  status                  String    @default("active")
  sourceRecommendationKey String?   @map("source_recommendation_key")
  priceEventId            String?   @map("price_event_id")
  revertAt                DateTime? @map("revert_at")
  revertedAt              DateTime? @map("reverted_at")
  notes                   String?
  payload                 Json?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  product                 Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// PostgreSQL partial unique index `temporary_price_actions_one_active_per_product_idx`
  /// is managed by migration `20260525033000_unique_active_temporary_price_action`.
  /// Prisma schema cannot represent partial indexes; keep that migration with the model.
  @@index([status, endAt])
  @@index([productId, status])
  @@index([sourceRecommendationKey])
  @@map("temporary_price_actions")
}

model ProductPriceEvent {
  id                String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId         String    @map("product_id")
  previousSalePrice Decimal?  @map("previous_sale_price") @db.Decimal(14, 4)
  salePrice         Decimal?  @map("sale_price") @db.Decimal(14, 4)
  source            String?
  payload           Json?
  createdAt         DateTime? @map("created_at")
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@map("product_price_events")
}

model Stock {
  id                String       @id @default(uuid())
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId         String       @unique @map("product_id")
  warehouseQuantity Int?         @map("warehouse_quantity")
  shelfQuantity     Int?         @map("shelf_quantity")
  quantity          Int?
  onHand            Int?         @map("on_hand")
  available         Int?
  reserved          Int?
  batchCount        Int?         @map("batch_count")
  nearestExpiry     String?      @map("nearest_expiry")
  fefoDefaultBatchNo String?     @map("fefo_default_batch_no")
  fefoDefaultExpiry String?      @map("fefo_default_expiry")
  payload           Json?
  updatedAt         DateTime?    @map("updated_at")
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches           StockBatch[]

  @@index([productId])
  @@map("stocks")
}

model StockBatch {
  id                String    @id @default(uuid())
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  stockId           String    @map("stock_id")
  productId         String    @map("product_id")
  batchNo           String    @map("batch_no")
  skt               String?
  warehouseQuantity Int?      @map("warehouse_quantity")
  shelfQuantity     Int?      @map("shelf_quantity")
  totalQuantity     Int?      @map("total_quantity")
  status            String?
  payload           Json?
  stock             Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([batchNo, skt])
  /// Partial positive-quantity variant is managed by migration
  /// `20260602090000_add_stock_batch_expiry_tracking_indexes`.
  @@index([tenantId, skt])
  @@map("stock_batches")
}

model StockMovement {
  id                    String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId             String?   @map("product_id")
  supplierId            String?   @map("supplier_id")
  productName           String?   @map("product_name")
  sku                   String?
  type                  String?
  qty                   Int?
  previousQuantity      Int?      @map("previous_quantity")
  nextQuantity          Int?      @map("next_quantity")
  previousTotalQuantity Int?      @map("previous_total_quantity")
  nextTotalQuantity     Int?      @map("next_total_quantity")
  location              String?
  fromLocation          String?   @map("from_location")
  toLocation            String?   @map("to_location")
  reasonCode            String?   @map("reason_code")
  reasonLabel           String?   @map("reason_label")
  referenceNo           String?   @map("reference_no")
  transferRequestId     String?   @map("transfer_request_id")
  userId                String?   @map("user_id")
  userName              String?   @map("user_name")
  batchNo               String?   @map("batch_no")
  skt                   String?
  payload               Json?
  createdAt             DateTime? @map("created_at")
  updatedAt             DateTime? @map("updated_at")
  product               Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier              Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user                  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  transferRequest       StockTransferRequest? @relation(fields: [transferRequestId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([referenceNo])
  @@index([createdAt])
  @@map("stock_movements")
}

model WarehouseLocation {
  id             String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  rowNo          Int?      @map("row_no")
  side           String?
  shelfNo        Int?      @map("shelf_no")
  levelNo        Int?      @map("level_no")
  locationCode   String?   @unique @map("location_code")
  storageType    String?   @map("storage_type")
  status         String?
  productId      String?   @map("product_id")
  productName    String?   @map("product_name")
  sku            String?
  barcode        String?
  supplierId     String?   @map("supplier_id")
  supplierName   String?   @map("supplier_name")
  batchNo        String?   @map("batch_no")
  skt            String?
  palletCount    Int?      @map("pallet_count")
  palletCapacity Int?      @map("pallet_capacity")
  occupancy      Decimal?  @db.Decimal(8, 3)
  warehouseStock Int?      @map("warehouse_stock")
  isReserved     Boolean?  @map("is_reserved")
  isBlocked      Boolean?  @map("is_blocked")
  payload        Json?
  createdAt      DateTime? @map("created_at")
  updatedAt      DateTime? @map("updated_at")
  product        Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements      WarehouseMovement[]

  @@map("warehouse_locations")
}

model WarehouseMovement {
  id            String             @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId     String?            @map("product_id")
  productName   String?            @map("product_name")
  sku           String?
  barcode       String?
  supplierId    String?            @map("supplier_id")
  supplierName  String?            @map("supplier_name")
  locationId    String?            @map("location_id")
  locationCode  String?            @map("location_code")
  batchNo       String?            @map("batch_no")
  skt           String?
  movementType  String?            @map("movement_type")
  qty           Int?
  createdBy     String?            @map("created_by")
  createdByName String?            @map("created_by_name")
  description   String?
  payload       Json?
  createdAt     DateTime?          @map("created_at")
  product       Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier      Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  location      WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  creator       User?              @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("warehouse_movements")
}

model SupplierProduct {
  id                  String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId           String?   @map("product_id")
  supplierId          String?   @map("supplier_id")
  supplierProductCode String?   @map("supplier_product_code")
  supplierProductName String?   @map("supplier_product_name")
  normalizedSearch    String?   @map("normalized_search")
  supplierSku         String?   @map("supplier_sku")
  barcode             String?
  purchasePrice       Decimal?  @map("purchase_price") @db.Decimal(14, 4)
  currency            String?
  minimumOrderQty     Int?      @map("minimum_order_qty")
  minOrderQty         Int?      @map("min_order_qty")
  leadTimeDays        Int?      @map("lead_time_days")
  isDefault           Boolean?  @map("is_default")
  isActive            Boolean?  @map("is_active")
  source              String?
  priceUnit           String?   @map("price_unit")
  minOrderUnit        String?   @map("min_order_unit")
  defaultOrderUnit    String?   @map("default_order_unit")
  unitsPerCase        Int?      @map("units_per_case")
  casesPerPallet      Int?      @map("cases_per_pallet")
  payload             Json?
  createdAt           DateTime? @map("created_at")
  updatedAt           DateTime? @map("updated_at")
  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier            Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([productId, supplierId])
  @@map("supplier_products")
}

model PurchaseSuggestion {
  id             String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  productId      String?   @map("product_id")
  categoryId     String?   @map("category_id")
  supplierId     String?   @map("supplier_id")
  currentStock   Int?      @map("current_stock")
  criticalStock  Int?      @map("critical_stock")
  suggestedQty   Int?      @map("suggested_qty")
  unitPrice      Decimal?  @map("unit_price") @db.Decimal(14, 4)
  totalPrice     Decimal?  @map("total_price") @db.Decimal(14, 4)
  status         String?
  reason         String?
  riskLevel      String?   @map("risk_level")
  payload        Json?
  createdAt      DateTime? @map("created_at")
  updatedAt      DateTime? @map("updated_at")
  product        Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
