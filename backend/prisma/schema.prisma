model Setting {
  id          String    @id @default("default")
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  storeId     String?   @map("store_id")
  systemName  String?   @map("system_name")
  companyName String?   @map("company_name")
  currency    String?
  timezone    String?
  payload     Json?
  updatedAt   DateTime? @map("updated_at")
  store       Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, storeId])
  @@index([storeId])
  @@map("settings")
}

model AccessRequest {
  id                       String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  userId                   String?   @map("user_id")
  storeId                  String?   @map("store_id")
  permission               String?
  reason                   String?
  requestedDurationMinutes Int?      @map("requested_duration_minutes")
  status                   String?
  createdBy                String?   @map("created_by")
  reviewedBy               String?   @map("reviewed_by")
  assignedTo               String?   @map("assigned_to")
  reviewNote               String?   @map("review_note")
  payload                  Json?
  createdAt                DateTime? @map("created_at")
  updatedAt                DateTime? @map("updated_at")
  reviewedAt               DateTime? @map("reviewed_at")
  user                     User?     @relation("AccessRequestUser", fields: [userId], references: [id], onDelete: SetNull)
  creator                  User?     @relation("AccessRequestCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  reviewer                 User?     @relation("AccessRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  grants                   TemporaryPermissionGrant[]

  @@map("access_requests")
}

model TemporaryPermissionGrant {
  id          String         @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  userId      String?        @map("user_id")
  permission  String?
  storeId     String?        @map("store_id")
  requestId   String?        @map("request_id")
  status      String?
  approvedBy  String?        @map("approved_by")
  reason      String?
  payload     Json?
  createdAt   DateTime?      @map("created_at")
  updatedAt   DateTime?      @map("updated_at")
  expiresAt   DateTime?      @map("expires_at")
  revokedAt   DateTime?      @map("revoked_at")
  revokedBy   String?        @map("revoked_by")
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  request     AccessRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  approver    User?          @relation("TemporaryGrantApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  revoker     User?          @relation("TemporaryGrantRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@map("temporary_permission_grants")
}

model AccessAuditLog {
  id         String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  action     String?
  userId     String?   @map("user_id")
  permission String?
  storeId    String?   @map("store_id")
  requestId  String?   @map("request_id")
  actorId    String?   @map("actor_id")
  actorIp    String?   @map("actor_ip")
  metadata   Json?
  payload    Json?
  createdAt  DateTime? @map("created_at")

  @@map("access_audit_logs")
}

model AuditLog {
  id            String    @id @default(uuid())
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  actorUserId   String?   @map("actor_user_id")
  actorName     String?   @map("actor_name")
  actorRole     String?   @map("actor_role")
  actorEmail    String?   @map("actor_email")
  action        String?
  module        String?
  entityType    String?   @map("entity_type")
  entityId      String?   @map("entity_id")
  entityLabel   String?   @map("entity_label")
  method        String?
  endpoint      String?
  statusCode    Int?      @map("status_code")
  ip            String?
  userAgent     String?   @map("user_agent")
  requestId     String?   @map("request_id")
  correlationId String?   @map("correlation_id")
  summary       String?
  metadata      Json?
  severity      String?   @default("info")
  source        String?   @default("user_action")
  archivedAt    DateTime? @map("archived_at")

  @@index([createdAt])
  @@index([actorUserId])
  @@index([module])
  @@index([action])
  @@index([source])
  @@index([statusCode])
  @@map("audit_logs")
}

model LoginActivityLog {
  id            String    @id @default(uuid())
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  userId        String?   @map("user_id")
  userType      String?   @map("user_type")
  name          String?
  email         String?
  username      String?
  role          String?
  department    String?
  eventType     String?   @map("event_type")
  source        String?
  status        String?
  ip            String?
  userAgent     String?   @map("user_agent")
  browser       String?
  os            String?
  requestId     String?   @map("request_id")
  failureReason String?   @map("failure_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  archivedAt    DateTime? @map("archived_at")

  @@index([createdAt])
  @@index([userId])
  @@index([userType])
  @@index([eventType])
  @@index([source])
  @@index([status])
  @@index([ip])
  @@map("login_activity_logs")
}

model CatalogImport {
  id               String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  supplierId       String?   @map("supplier_id")
  supplierName     String?   @map("supplier_name")
  fileName         String?   @map("file_name")
  uploadedAt       DateTime? @map("uploaded_at")
  uploadedBy       String?   @map("uploaded_by")
  status           String?
  validityStart    DateTime? @map("validity_start")
  validityEnd      DateTime? @map("validity_end")
  summary          Json?
  rows             Json?
  requiredApproval Boolean?  @map("required_approval")
  columnsValidated Boolean?  @map("columns_validated")
  payload          Json?
  supplier         Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@map("catalog_imports")
}

model SupplierCatalogVersion {
  id         String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  supplierId String?   @map("supplier_id")
  status     String?
  rows       Json?
  payload    Json?
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("supplier_catalog_versions")
}

model SupportTicket {
  id          String    @id
  tenantId             String    @default("tenant_main_shelfio") @map("tenant_id")
  subject     String?
  description String?
  userId      String?   @map("user_id")
  user        String?
  role        String?
  page        String?
  browser     String?
  attachments Json?
  status      String?
  payload     Json?
  createdAt   DateTime? @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  @@map("support_tickets")
}

