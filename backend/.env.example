# Shelfio backend production environment example
# Copy to backend/.env on the VPS and replace placeholders with real values.
# Do not commit real secrets.

NODE_ENV=production
PORT=4000
DATA_STORE=postgres
RUN_STARTUP_MAINTENANCE=false
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
# Prisma migrations require permission to create the pg_trgm extension used by
# product/supplier search indexes. If the VPS DB user cannot run CREATE EXTENSION,
# install pg_trgm once with a superuser before `npx prisma migrate deploy`.
# SQL: CREATE EXTENSION IF NOT EXISTS pg_trgm;

# Auth secrets: use long, random, unique values in production.
JWT_SECRET=change-me-strong-access-token-secret
JWT_EXPIRES_IN=8h
CUSTOMER_REFRESH_SECRET=change-me-strong-customer-refresh-secret
CUSTOMER_REFRESH_EXPIRES_IN=30d

# Public/reverse proxy URLs
PUBLIC_API_BASE_URL=https://example.com
CORS_ORIGIN=https://example.com

# ESL bridge/device heartbeat. Use the same token on production backend and local bridge.
ESL_DEVICE_TOKEN=change-this-long-random-token
# Optional per-device override format: esl-dev-3:token-a,esl-dev-4:token-b
# ESL_DEVICE_TOKENS=
ESL_HEARTBEAT_RATE_LIMIT_PER_MINUTE=20

# Customer proximity product discount dedupe. Production default is 12 hours (43200).
# For test/demo only, set to 60 or 120 to allow repeated same-product demos.
PROXIMITY_PRODUCT_DEDUPE_SECONDS=43200

# Support uploads. Use a persistent VPS directory and include it in backups.
SUPPORT_UPLOAD_DIR=/var/www/shelfio/storage/support-uploads

# SMTP support mail
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@shelfiolabs.com
SMTP_PASS=change-me-smtp-password
SMTP_FROM_NAME=Shelfio Personel
SMTP_FROM_EMAIL=info@shelfiolabs.com
SMTP_REPLY_TO=personel@shelfiolabs.com
SUPPORT_TO_EMAIL=admin@shelfiolabs.com
