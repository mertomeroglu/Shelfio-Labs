{
  "name": "stock-tracking-backend",
  "version": "1.0.0",
  "description": "PostgreSQL-backed Shelfio backend",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --watch src src/index.js",
    "start": "node src/index.js",
    "start:prod": "node src/index.js",
    "test": "node --test",
    "esl:bridge": "node scripts/bridge/eslBridgeAgent.js",
    "labels:sync": "node scripts/sync/syncCategoryLabels.js",
    "seed:orders:lifecycle": "node scripts/seed/seedOrderLifecycleTestData.js",
    "seed:customer-proximity": "node scripts/seedCustomerProximity.js",
    "ensure:owner-permissions": "node scripts/ensureOwnerPermissions.js",
    "repair:retail-case-stock:postgres": "node scripts/repair/repairRetailShelfStockPolicyPostgres.js",
    "repair:batch-nos:postgres": "node scripts/repair/renumberBatchNos.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^7.8.0"
  }
}
